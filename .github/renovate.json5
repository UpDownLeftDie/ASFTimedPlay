{
	$schema: "https://docs.renovatebot.com/renovate-schema.json",

	extends: [
		"config:best-practices",
		":assignee(jaredcat)",
		":automergeBranch",
		":automergeDigest",
		":automergeMinor",
		":disableDependencyDashboard",
		":disableRateLimiting",
		":label(🤖 Automatic)",
	],

	"git-submodules": {
		enabled: true,
	},
}
